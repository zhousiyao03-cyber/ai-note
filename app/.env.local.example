# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Inngest (optional for local dev; Inngest dev server auto-discovers)
# INNGEST_EVENT_KEY=
# INNGEST_SIGNING_KEY=

# OpenAI (Phase 2; without this key the worker falls back to a mock transcript in local/dev)
# OPENAI_API_KEY=

# Stripe (Phase 4 billing)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
