# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SECRET_KEY=your-secret-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Postgres
POSTGRES_DATABASE=postgres
POSTGRES_HOST=db.your-project.supabase.co
POSTGRES_PASSWORD=your-postgres-password
POSTGRES_PRISMA_URL=postgres://postgres.your-project:your-postgres-password@your-pooler-host:6543/postgres?sslmode=require&pgbouncer=true
POSTGRES_URL=postgres://postgres.your-project:your-postgres-password@your-pooler-host:6543/postgres?sslmode=require
POSTGRES_URL_NON_POOLING=postgres://postgres.your-project:your-postgres-password@your-direct-host:5432/postgres?sslmode=require
POSTGRES_USER=postgres

# Inngest (optional for local dev; Inngest dev server auto-discovers)
# INNGEST_EVENT_KEY=
# INNGEST_SIGNING_KEY=

# OpenAI (Phase 2; without this key the worker falls back to a mock transcript in local/dev)
# OPENAI_API_KEY=

# Stripe (Phase 4 billing)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
